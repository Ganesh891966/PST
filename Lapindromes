import sys
from collections import Counter

t = int(sys.stdin.readline())
for _ in range(t):
    s = sys.stdin.readline().strip()
    n = len(s)
    mid = n // 2
    
    if n % 2 == 0:
        left = s[:mid]
        right = s[mid:]
    else:
        left = s[:mid]
        right = s[mid+1:]
    
    if Counter(left) == Counter(right):
        print("YES")
    else:
        print("NO")
